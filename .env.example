# Local development SQLite fallback.
# Leave unset to use data/chief-of-staff.db.
DATABASE_URL=file:./data/chief-of-staff.db

# Hosted Supabase/Postgres persistence.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional legacy hosted Turso/libSQL persistence.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# iPhone Shortcut capture API.
# Generate a long random value and never commit a real token.
CAPTURE_API_TOKEN=

# Optional model-backed extraction.
MODEL_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1-mini
